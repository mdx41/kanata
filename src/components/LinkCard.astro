---
interface Props {
  url: string;
  title: string;
  description: string;
  siteName: string;
  image?: string;
}

const { url, title, description, siteName, image } = Astro.props;
const hostname = (() => {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return siteName;
  }
})();
---

<a class:list={['link-card', { 'link-card--no-image': !image }]} href={url} target="_blank" rel="noopener noreferrer">
  <span class="link-card__body">
    <span class="link-card__site">{siteName || hostname}</span>
    <span class="link-card__title">{title}</span>
    <span class="link-card__description">{description}</span>
    <span class="link-card__url">{hostname}</span>
  </span>
  {image && (
    <span class="link-card__media" aria-hidden="true">
      <img src={image} alt="" loading="lazy" decoding="async" />
    </span>
  )}
</a>

<style>
  .link-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 132px;
    gap: 16px;
    align-items: stretch;
    margin: 1.35rem 0;
    padding: 14px;
    border: 1px solid var(--color-border, color-mix(in srgb, currentColor 16%, transparent));
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
    background: color-mix(in srgb, var(--color-bg, Canvas) 96%, currentColor 4%);
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      transform 160ms ease;
  }

  .link-card:hover {
    border-color: color-mix(in srgb, currentColor 34%, transparent);
    background: color-mix(in srgb, var(--color-bg, Canvas) 92%, currentColor 8%);
    transform: translateY(-1px);
  }

  .link-card:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  .link-card--no-image {
    grid-template-columns: minmax(0, 1fr);
  }

  .link-card__body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .link-card__site,
  .link-card__url {
    color: var(--color-muted, color-mix(in srgb, currentColor 62%, transparent));
    font-size: 0.76rem;
    line-height: 1.35;
  }

  .link-card__site {
    font-weight: 650;
    letter-spacing: 0;
  }

  .link-card__title {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .link-card__description {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    color: var(--color-muted, color-mix(in srgb, currentColor 70%, transparent));
    font-size: 0.86rem;
    line-height: 1.65;
  }

  .link-card__media {
    overflow: hidden;
    border-radius: 6px;
    background: color-mix(in srgb, currentColor 8%, transparent);
  }

  .link-card__media img {
    width: 100%;
    height: 100%;
    min-height: 104px;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 640px) {
    .link-card {
      grid-template-columns: minmax(0, 1fr);
      gap: 12px;
      padding: 12px;
    }

    .link-card__media {
      order: -1;
      aspect-ratio: 16 / 9;
    }

    .link-card__media img {
      min-height: 0;
    }
  }
</style>
