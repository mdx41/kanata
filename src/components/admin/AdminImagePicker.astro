---
import AdminIcon from './AdminIcon.astro';

interface Props {
  listEndpoint: string;
  metaEndpoint: string;
}

const { listEndpoint, metaEndpoint } = Astro.props;
---

<dialog
  class="admin-images-picker"
  data-admin-images-picker
  data-list-endpoint={listEndpoint}
  data-meta-endpoint={metaEndpoint}
  aria-labelledby="admin-images-picker-title"
>
  <div class="admin-images-picker__surface">
    <div class="admin-images-picker__header">
      <div class="admin-images-picker__topbar">
        <div class="admin-images-picker__copy">
          <h2 id="admin-images-picker-title" class="admin-images-picker__title" data-admin-images-picker-title>
            ローカル画像を選択
          </h2>
        </div>
        <span class="admin-images-picker__header-divider" aria-hidden="true"></span>
        <div class="admin-images-picker__header-controls">
          <button
            class="admin-btn admin-btn--tool admin-btn--compact admin-images-picker__filter-toggle"
            type="button"
            data-admin-images-picker-filter-toggle
            aria-controls="admin-images-picker-filters"
            aria-expanded="false"
            hidden
          >
            <AdminIcon name="funnel" size={16} />
            <span>フィルター</span>
          </button>
          <div
            id="admin-images-picker-filters"
            class="admin-images-picker__filters"
            data-admin-images-picker-filters
            hidden
          >
            <div class="admin-images-picker__filter-tabs" data-admin-images-picker-filter-tabs></div>
          </div>
          <label class="admin-field admin-field--compact admin-images-picker__search">
            <span class="admin-sr-only">パスまたはファイル名を検索</span>
            <input
              class="admin-field__control"
              type="search"
              inputmode="search"
              autocomplete="off"
              placeholder="パスまたはファイル名を検索，如hero"
              data-admin-images-picker-query
            />
          </label>
          <p class="admin-images-picker__status" data-admin-images-picker-status aria-live="polite">読み込み待ち</p>
        </div>
        <div class="admin-images-picker__tool-actions">
          <button
            class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-images-picker__tool-btn"
            type="button"
            data-admin-images-picker-view="list"
            aria-label="リスト表示"
            title="リスト表示"
          >
            <AdminIcon name="list" size={18} />
          </button>
          <button
            class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-images-picker__tool-btn"
            type="button"
            data-admin-images-picker-view="grid"
            aria-label="グリッド表示"
            title="グリッド表示"
          >
            <AdminIcon name="grid-tiles" size={18} />
          </button>
        </div>
        <button
          class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-images-picker__icon-btn"
          type="button"
          data-admin-images-picker-close
          aria-label="閉じる"
          title="閉じる"
        >
          <AdminIcon name="x-mark" size={18} />
        </button>
      </div>

      <p
        id="admin-images-picker-description"
        class="admin-images-picker__description"
        data-admin-images-picker-description
        hidden
      ></p>
    </div>

    <ul class="admin-images-picker__results" data-admin-images-picker-results data-view="list"></ul>

    <div class="admin-images-picker__footer">
      <div class="admin-images-picker__footer-side admin-images-picker__footer-side--start">
        <button class="admin-btn admin-btn--secondary" type="button" data-admin-images-picker-reset hidden>恢复默认</button>
      </div>
      <div class="admin-images-picker__pager" role="group" aria-label="画像一覧のページ切り替え">
        <button
          class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-images-picker__pager-btn"
          type="button"
          data-admin-images-picker-prev
          aria-label="前のページ"
          title="前のページ"
        >
          <AdminIcon
            name="chevron-down"
            size={22}
            strokeWidth={1.75}
            class="admin-images-picker__pager-icon admin-images-picker__pager-icon--prev"
          />
        </button>
        <span class="admin-images-picker__page" data-admin-images-picker-page aria-live="polite">1 / 1</span>
        <button
          class="admin-btn admin-btn--tool admin-btn--compact admin-btn--icon admin-images-picker__pager-btn"
          type="button"
          data-admin-images-picker-next
          aria-label="次のページ"
          title="次のページ"
        >
          <AdminIcon
            name="chevron-down"
            size={22}
            strokeWidth={1.75}
            class="admin-images-picker__pager-icon admin-images-picker__pager-icon--next"
          />
        </button>
      </div>
      <div class="admin-images-picker__footer-side admin-images-picker__footer-side--end">
        <div class="admin-images-picker__actions">
          <button class="admin-btn admin-btn--primary" type="button" data-admin-images-picker-confirm disabled>選択した画像を使う</button>
        </div>
      </div>
    </div>
  </div>
</dialog>
