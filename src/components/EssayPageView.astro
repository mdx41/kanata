---
import BaseLayout from '../layouts/BaseLayout.astro';
import TagFilterHeader from './TagFilterHeader.astro';
import EssayCard from './EssayCard.astro';
import { createWithBase, getEssayDerivedText, getEssaySlug, type EssayEntry } from '../lib/content';
import { getThemeSettings, getVisibleArticleMetaTags } from '../lib/theme-settings';
import { joinPageSubtitleText } from '../utils/format';

const {
  currentPage,
  items,
  nextPath = null,
  prevPath = null,
  resultCount,
  totalPages
} = Astro.props as {
  currentPage: number;
  items: EssayEntry[];
  nextPath?: string | null;
  prevPath?: string | null;
  resultCount: number;
  totalPages: number;
};

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const {
  settings: {
    page,
    ui: { articleMeta }
  }
} = getThemeSettings();

const pageTitleText = page.essay.title || '記事';
const pageTitleParts = [pageTitleText, currentPage > 1 ? `${currentPage}ページ目` : null].filter(Boolean);
const pageTitle = pageTitleParts.join(' | ');
const subtitleText = joinPageSubtitleText(
  page.essay.subtitle,
  `${resultCount}件の記事`,
  totalPages > 1 ? `${currentPage} / ${totalPages}ページ` : null
);
const pageDescription = joinPageSubtitleText(
  `${pageTitleText}一覧`,
  page.essay.subtitle,
  `${resultCount}件の記事`,
  totalPages > 1 ? `${currentPage} / ${totalPages}ページ` : null
) ?? `${pageTitleText}一覧`;
const fallbackListId = 'essay-tag-list';
---

<BaseLayout title={pageTitle} description={pageDescription} bodyClass="essay-page">
  <div
    class="entry-filters"
    data-entry-filters
    data-index-url="/essay/index.json"
  >
    <TagFilterHeader
      pageTitleText={pageTitleText}
      subtitleText={subtitleText}
      rssHref={withBase('/essay/rss.xml')}
      pickerHref={`#${fallbackListId}`}
      fallbackListId={fallbackListId}
      dialogTitleId="essay-tag-dialog-title"
      searchAriaLabel={`${pageTitleText}を検索`}
      headerClass="page-header page-header--essay page-header--with-search"
    />
  </div>

  <div class="list">
    {items.map((entry) => (
      <EssayCard
        href={withBase(`/archive/${getEssaySlug(entry)}/`)}
        slug={getEssaySlug(entry)}
        title={entry.data.title}
        excerpt={getEssayDerivedText(entry).excerpt}
        date={entry.data.date}
        visibleTags={getVisibleArticleMetaTags(entry.data.tags, 'list')}
        articleMetaSettings={articleMeta}
        badge={entry.data.badge}
      />
    ))}
  </div>

  {totalPages > 1 ? (
    <nav class="pagination" aria-label={`${pageTitleText}のページ送り`}>
      <div class="pagination__inner">
        {prevPath ? <a class="pagination__link" rel="prev" href={withBase(prevPath)}>前のページ</a> : null}
        {nextPath ? (
          <a class="pagination__link pagination__link--next" rel="next" href={withBase(nextPath)}>次のページ</a>
        ) : null}
      </div>
    </nav>
  ) : null}

  <script>
    import '../scripts/entry-search.ts';
  </script>
</BaseLayout>
