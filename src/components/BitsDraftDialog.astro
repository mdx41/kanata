---
import UiIcon from './UiIcon.astro';
import { getThemeSettings } from '../lib/theme-settings';

const { settings } = getThemeSettings();
---
<dialog
  class="bits-draft-dialog"
  id="bits-draft-dialog"
  aria-labelledby="bits-draft-title"
  data-default-author-name={settings.page.bits.defaultAuthor.name ?? ''}
  data-default-author-avatar={settings.page.bits.defaultAuthor.avatar ?? ''}
>
  <form class="bits-draft-form" data-bits-draft-form>
    <div class="bits-draft-head">
      <h2 id="bits-draft-title">
        <span class="bits-draft-title-icon" aria-hidden="true">
          <UiIcon name="pen" />
        </span>
        ひとことを書く
      </h2>
      <button class="bits-draft-close" type="button" data-bits-draft-close aria-label="閉じる">×</button>
    </div>

    <div class="bits-draft-field">
      <div class="bits-draft-field-head">
        <label for="bits-draft-content">本文</label>
        <div class="bits-draft-toolbar" data-bits-draft-toolbar role="toolbar" aria-label="よく使う書式">
          <button type="button" class="bits-draft-tool" data-action="bold" data-tip="太字" aria-label="太字">
            <UiIcon name="bold" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="italic" data-tip="斜体" aria-label="斜体">
            <UiIcon name="italic" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="code" data-tip="インラインコード" aria-label="インラインコード">
            <UiIcon name="code" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="quote" data-tip="引用" aria-label="引用">
            <UiIcon name="quote" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="list" data-tip="リスト" aria-label="リスト">
            <UiIcon name="list" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="link" data-tip="リンク" aria-label="リンク">
            <UiIcon name="link" />
          </button>
          <button type="button" class="bits-draft-tool" data-action="paragraph" data-tip="段落" aria-label="段落">
            <UiIcon name="paragraph" />
          </button>
        </div>
      </div>
      <textarea
        id="bits-draft-content"
        name="content"
        rows="6"
        required
        placeholder="何か書いてみましょう..."
      ></textarea>
    </div>

    <div class="bits-draft-row">
      <div class="bits-draft-field bits-draft-half">
        <label for="bits-draft-tags" class="bits-draft-label">
          <span class="bits-draft-label-icon" aria-hidden="true">#</span>
          タグ
        </label>
        <input id="bits-draft-tags" name="tags" type="text" inputmode="text" placeholder="カンマまたは空白で区切る" />
        <div class="bits-draft-help">例: 日常 読書 / life reading</div>
      </div>
      <div class="bits-draft-field bits-draft-half">
        <label for="bits-draft-place" class="bits-draft-label">
          <span class="bits-draft-label-icon" aria-hidden="true">
            <UiIcon name="map-pin" />
          </span>
          場所（任意）
        </label>
        <input id="bits-draft-place" name="place" type="text" inputmode="text" placeholder="例: 東京" />
        <div class="bits-draft-help">tagsに loc:&lt;場所&gt; を追加します</div>
      </div>
    </div>

    <div class="bits-draft-stack">
      <div class="bits-draft-field">
        <div class="bits-draft-field-head bits-draft-image-head">
          <div class="bits-draft-field-title">
            <label>画像を追加（任意）</label>
            <button class="bits-draft-image-add" type="button" data-bits-image-add>+ 追加</button>
          </div>
          <div class="bits-draft-help">画像は public/bits/images/ に置き、src は bits/images/... と入力します。サイズは自動で読み取ります</div>
        </div>
        <div class="bits-draft-images" data-bits-images>
          <div class="bits-draft-image-row" data-bits-image-row>
            <div class="bits-draft-image-src-wrap">
              <input
                class="bits-draft-image-src"
                data-bits-image-src
                type="text"
                inputmode="url"
                placeholder="bits/images/example.webp または https://..."
              />
              <button class="bits-draft-image-clear" type="button" data-bits-image-remove aria-label="画像を削除">x</button>
            </div>
            <input
              class="bits-draft-image-dim"
              data-bits-image-width
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="幅"
            />
            <input
              class="bits-draft-image-dim"
              data-bits-image-height
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="高さ"
            />
          </div>
        </div>
        <template data-bits-image-template>
          <div class="bits-draft-image-row" data-bits-image-row>
            <div class="bits-draft-image-src-wrap">
              <input
                class="bits-draft-image-src"
                data-bits-image-src
                type="text"
                inputmode="url"
                placeholder="bits/images/example.webp または https://..."
              />
              <button class="bits-draft-image-clear" type="button" data-bits-image-remove aria-label="画像を削除">x</button>
            </div>
            <input
              class="bits-draft-image-dim"
              data-bits-image-width
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="幅"
            />
            <input
              class="bits-draft-image-dim"
              data-bits-image-height
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="高さ"
            />
          </div>
        </template>
      </div>

      <div class="bits-draft-status" data-bits-draft-status role="status" aria-live="polite"></div>
      <div class="bits-draft-link-row">
        <button class="bits-draft-link" type="button" data-bits-manual-open hidden>
          <span class="bits-draft-link-icon" aria-hidden="true">
            <UiIcon name="eye" />
          </span>
          <span>下書きをプレビュー</span>
          <span class="bits-draft-link-caret" aria-hidden="true">
            <UiIcon name="chevron-down" />
          </span>
        </button>
      </div>

      <div class="bits-draft-manual" data-bits-manual hidden>
        <div class="bits-draft-manual-title">下書き内容（読み取り専用）</div>
        <textarea class="bits-draft-manual-textarea" data-bits-manual-textarea rows="6" readonly></textarea>
        <div class="bits-draft-manual-actions">
          <div class="bits-draft-manual-note" data-bits-manual-note></div>
          <button class="bits-draft-secondary" type="button" data-bits-manual-copy>手動でコピー</button>
        </div>
      </div>

      <div class="bits-identity-bar" data-identity-bar>
        <div class="bits-identity-caption">
          <span class="bits-identity-label-icon" aria-hidden="true">
            <UiIcon name="user-circle" />
          </span>
          <span id="bits-identity-heading">投稿者（任意）</span>
        </div>
        <div class="bits-identity-row">
          <div class="bits-identity-controls">
            <button
              class="bits-identity-pill"
              type="button"
              data-identity-pill
              aria-controls="bits-identity-panel"
              aria-expanded="false"
            >
              <span class="bits-identity-avatar" data-identity-avatar aria-hidden="true"></span>
              <span class="bits-identity-name" data-identity-name></span>
            </button>
          </div>
          <button
            class="bits-identity-new"
            type="button"
            data-identity-new
            aria-controls="bits-identity-panel"
            aria-expanded="false"
          >
            投稿者を変更
          </button>
        </div>
      </div>

      <div
        id="bits-identity-panel"
        class="bits-identity-advanced"
        data-identity-panel
        role="group"
        aria-labelledby="bits-identity-heading"
        hidden
      >
        <div class="bits-identity-fields">
          <label class="bits-identity-label">
            <span class="bits-identity-label-title">投稿者名</span>
            <input type="text" name="authorName" inputmode="text" data-author-name />
          </label>
          <label class="bits-identity-label">
            <span class="bits-identity-label-row">
              <span class="bits-identity-label-title">アバター画像パス（URL）</span>
              <span class="bits-identity-label-hint">空欄なら既定のアバターを使います。読み込みに失敗した場合は頭文字を表示します。</span>
            </span>
            <input type="text" name="authorAvatar" inputmode="url" data-author-avatar />
          </label>
        </div>
        <div class="bits-identity-meta">
          <p class="bits-identity-note">
            空欄なら現在の投稿者を使い、この投稿にはauthorを書き込みません。
          </p>
          <button type="button" class="bits-identity-reset" data-author-reset>既定に戻す</button>
        </div>
      </div>
    </div>

    <div class="bits-draft-footer">
      <div class="bits-draft-check">
        <input id="bits-draft-draft" name="draft" type="checkbox" />
        <label for="bits-draft-draft">下書きにする</label>
        <span class="bits-draft-check-help">下書きは本番/プレビューで既定では表示されません</span>
      </div>
      <div class="bits-draft-actions">
        <button class="bits-draft-primary" type="button" data-bits-draft-generate>生成してコピー</button>
        <button class="bits-draft-secondary" type="button" data-bits-draft-download>.mdをダウンロード</button>
      </div>
    </div>
  </form>
</dialog>
