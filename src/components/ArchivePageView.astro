---
import BaseLayout from '../layouts/BaseLayout.astro';
import TagFilterHeader from './TagFilterHeader.astro';
import { createWithBase, getEssaySlug, type EssayEntry } from '../lib/content';
import { getTagPath, type TagSummary } from '../lib/tags';
import { getThemeSettings } from '../lib/theme-settings';
import { formatISODateUtc, formatMonthDayUtc, groupByUtcYear, joinPageSubtitleText } from '../utils/format';

const {
  currentPage,
  currentPath,
  currentTag = null,
  items,
  nextPath = null,
  prevPath = null,
  resultCount,
  tagSummaries,
  totalPages
} = Astro.props as {
  currentPage: number;
  currentPath: string;
  currentTag?: TagSummary | null;
  items: EssayEntry[];
  nextPath?: string | null;
  prevPath?: string | null;
  resultCount: number;
  tagSummaries: TagSummary[];
  totalPages: number;
};

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const {
  settings: {
    page
  }
} = getThemeSettings();

const pageTitleText = page.archive.title || 'アーカイブ';
const pageTitleParts = [pageTitleText, currentTag ? `#${currentTag.label}` : null, currentPage > 1 ? `${currentPage}ページ目` : null]
  .filter(Boolean);
const pageTitle = pageTitleParts.join(' | ');
const subtitleText = joinPageSubtitleText(
  page.archive.subtitle,
  `${resultCount}件の記事`,
  totalPages > 1 ? `${currentPage} / ${totalPages}ページ` : null
);
const pageDescription = joinPageSubtitleText(
  currentTag ? `アーカイブタグ #${currentTag.label}` : `${pageTitleText}一覧`,
  page.archive.subtitle,
  `${resultCount}件の記事`,
  totalPages > 1 ? `${currentPage} / ${totalPages}ページ` : null
) ?? `${pageTitleText}一覧`;
const groups = groupByUtcYear(items, (entry) => entry.data.date);
const scopeRootPath = '/archive/';
const fallbackListId = 'archive-tag-list';
const tagOptions = tagSummaries.map((tagSummary) => ({
  ...tagSummary,
  href: withBase(currentTag?.key === tagSummary.key ? currentPath : getTagPath('archive', tagSummary.key)),
  isActive: currentTag?.key === tagSummary.key
}));
const currentTagState = currentTag
  ? {
      clearHref: withBase(scopeRootPath),
      label: currentTag.label
    }
  : null;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div
    class="entry-filters"
    data-entry-filters
    data-index-url="/archive/index.json"
    data-section-selector="[data-entry-section]"
    data-tag-scope="archive"
    data-active-tag-key={currentTag?.key ?? undefined}
    data-active-tag-label={currentTag?.label ?? undefined}
  >
    <TagFilterHeader
      pageTitleText={pageTitleText}
      subtitleText={subtitleText}
      rssHref={withBase('/archive/rss.xml')}
      pickerHref={`#${fallbackListId}`}
      fallbackListId={fallbackListId}
      dialogTitleId="archive-tag-dialog-title"
      currentTag={currentTagState}
      tagOptions={tagOptions}
      searchAriaLabel={`${pageTitleText}を検索`}
    />
  </div>

  {groups.map((group) => (
    <section data-entry-section>
      <h2 class="archive-year">{group.year}</h2>
      <div class="archive-list">
        {group.list.map((entry) => {
          const slug = getEssaySlug(entry);
          const href = withBase(`/archive/${slug}/`);
          const tag = currentTag?.label ?? entry.data.tags?.[0];
          return (
            <div class="archive-row" data-entry-item data-slug={slug}>
              <div class="archive-title">
                <a href={href}>{entry.data.title}</a>
              </div>
              <div class="archive-meta">
                <div class="archive-date">
                  <span class="archive-date-md">{formatMonthDayUtc(entry.data.date)}</span>
                  <span class="archive-date-full">{formatISODateUtc(entry.data.date)}</span>
                </div>
                {tag ? <div class="archive-tag">#{tag}</div> : null}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  ))}

  {totalPages > 1 ? (
    <nav class="pagination" aria-label={`${pageTitleText}のページ送り`}>
      <div class="pagination__inner">
        {prevPath ? <a class="pagination__link" rel="prev" href={withBase(prevPath)}>前のページ</a> : null}
        {nextPath ? (
          <a class="pagination__link pagination__link--next" rel="next" href={withBase(nextPath)}>次のページ</a>
        ) : null}
      </div>
    </nav>
  ) : null}

  <script>
    import '../scripts/entry-search.ts';
  </script>
</BaseLayout>
