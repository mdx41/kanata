---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import AdminDiagnosticPanel from '../../../components/admin/AdminDiagnosticPanel.astro';
import AdminImagePicker from '../../../components/admin/AdminImagePicker.astro';
import AdminReadonlyNotice from '../../../components/admin/AdminReadonlyNotice.astro';
import AdminShell from '../../../components/admin/AdminShell.astro';
import {
  ADMIN_CONTENT_COLLECTIONS,
  ADMIN_CONTENT_DRAFT_OPTIONS,
  ADMIN_CONTENT_SORT_OPTIONS,
  getAdminContentCollectionHref,
  getAdminContentCollectionPageData,
  getAdminContentPublicFallbackLabel,
  isAdminContentCollectionKey,
  type AdminContentCollectionKey
} from '../../../lib/admin-console/content';
import {
  ADMIN_IMAGE_LIST_API_PATH,
  ADMIN_IMAGE_META_API_PATH
} from '../../../lib/admin-console/image-shared';
import { readAdminContentEntryEditorPayload } from '../../../lib/admin-console/content-shared';
import { createWithBase } from '../../../utils/format';

export const getStaticPaths = () =>
  ADMIN_CONTENT_COLLECTIONS.map((collection) => ({
    params: { collection }
  }));

const collectionParam = Astro.params.collection;
if (!isAdminContentCollectionKey(collectionParam ?? '')) {
  throw new Error(`Unsupported admin content collection route: ${collectionParam ?? '(missing)'}`);
}

const collection: AdminContentCollectionKey = collectionParam;

const isDev = import.meta.env.DEV;
// コンテンツ管理は現在 dev 環境でも一時停止中。実装は将来の管理UI再構築用に残しています。
const isAdminContentConsoleEnabled: boolean = false;
const shouldShowContentConsole = isDev && isAdminContentConsoleEnabled;
const shouldShowAdminNav = isDev;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const { default: adminShellStylesHref } = await import('../../../styles/components/admin-shell.css?url');

const loadContentDevState = async () => {
  const [
    { default: adminContentScriptHref },
    { default: adminContentStylesHref },
    { default: adminImageSharedStylesHref }
  ] = await Promise.all([
    import('../../../scripts/admin-content/index.ts?url'),
    import('../../../styles/components/admin-content.css?url'),
    import('../../../styles/components/admin-images-shared.css?url')
  ]);

  return {
    adminContentScriptHref,
    stylesHref: [adminShellStylesHref, adminContentStylesHref, adminImageSharedStylesHref],
    pageData: await getAdminContentCollectionPageData(collection, Astro.url.searchParams)
  };
};

const contentDevState = shouldShowContentConsole ? await loadContentDevState() : null;
const pageData = contentDevState?.pageData ?? null;
const adminStylesHref = contentDevState?.stylesHref ?? adminShellStylesHref;
const currentCollectionHref = getAdminContentCollectionHref(collection);
const selectedEntryEditorPayload = shouldShowContentConsole && pageData?.selectedEntry
  ? await readAdminContentEntryEditorPayload(collection, pageData.selectedEntry.id)
  : null;
const selectedEntryRelativePath = selectedEntryEditorPayload?.relativePath ?? pageData?.selectedEntry?.relativePath ?? '';
const adminContentBootstrap = selectedEntryEditorPayload?.writable
  ? JSON.stringify({
      endpoint: withBase('/api/admin/content/entry'),
      collection: selectedEntryEditorPayload.collection,
      entryId: selectedEntryEditorPayload.entryId,
      revision: selectedEntryEditorPayload.revision
    })
  : null;
const adminImageListEndpoint = withBase(ADMIN_IMAGE_LIST_API_PATH);
const adminImageMetaEndpoint = withBase(ADMIN_IMAGE_META_API_PATH);
const contentConsoleSubtitle = pageData
  ? `${pageData.collectionLabel} · ${selectedEntryEditorPayload?.writable ? 'frontmatter 編集' : '読み取り専用インデックス'}`
  : 'コンテンツ索引';

type AdminBitsImageRow = {
  src: string;
  width: string;
  height: string;
  alt: string;
};

const parseInitialBitsImages = (value: string): AdminBitsImageRow[] => {
  try {
    const parsed = JSON.parse(value) as unknown;
    if (!Array.isArray(parsed)) return [];
    return parsed
      .filter((item): item is Record<string, unknown> => typeof item === 'object' && item !== null && !Array.isArray(item))
      .map((item) => ({
        src: typeof item.src === 'string' ? item.src : '',
        width: item.width == null ? '' : String(item.width),
        height: item.height == null ? '' : String(item.height),
        alt: typeof item.alt === 'string' ? item.alt : ''
      }));
  } catch {
    return [];
  }
};

const selectedBitsImageRows = selectedEntryEditorPayload?.collection === 'bits'
  ? parseInitialBitsImages(selectedEntryEditorPayload.values.imagesText)
  : [];
const bitsImageRows = selectedBitsImageRows.length > 0
  ? selectedBitsImageRows
  : [{ src: '', width: '', height: '', alt: '' }];

const buildCollectionQuery = (
  overrides: {
    q?: string;
    draft?: string;
    tag?: string;
    year?: string;
    sort?: string;
    page?: string;
    entry?: string;
  } = {}
) => {
  if (!pageData) return '';

  const params = new URLSearchParams();
  const append = (key: string, value: string) => {
    const normalized = value.trim();
    if (normalized) params.set(key, normalized);
  };

  append('q', overrides.q ?? pageData.filterState.query);

  const draft = (overrides.draft ?? pageData.filterState.draft).trim();
  if (draft && draft !== 'all') params.set('draft', draft);

  const tag = (overrides.tag ?? pageData.filterState.tag).trim();
  if (tag) params.set('tag', tag);

  const year = (overrides.year ?? (pageData.filterState.year !== null ? String(pageData.filterState.year) : '')).trim();
  if (year) params.set('year', year);

  const sort = (overrides.sort ?? pageData.filterState.sort).trim();
  if (sort && sort !== 'recent') params.set('sort', sort);

  const page = (overrides.page ?? (pageData.currentPage > 1 ? String(pageData.currentPage) : '')).trim();
  if (page && page !== '1') params.set('page', page);

  const entry = (overrides.entry ?? pageData.filterState.entry).trim();
  if (entry) params.set('entry', entry);

  const query = params.toString();
  return query ? `?${query}` : '';
};

const buildCurrentCollectionHref = (
  overrides: Parameters<typeof buildCollectionQuery>[0] = {}
) => withBase(`${currentCollectionHref}${buildCollectionQuery(overrides)}`);

const resetHref = withBase(currentCollectionHref);
const activeFilterCount = pageData
  ? [
      pageData.filterState.query.length > 0,
      pageData.filterState.draft !== 'all',
      pageData.filterState.tag.length > 0,
      pageData.filterState.year !== null,
      pageData.filterState.sort !== 'recent'
    ].filter(Boolean).length
  : 0;
---

<AdminLayout title="コンテンツ管理" stylesHref={adminStylesHref}>
  <AdminShell
    currentRoute="content"
    title="コンテンツ管理"
    subtitle={contentConsoleSubtitle}
    showNav={shouldShowAdminNav}
  >
    {shouldShowContentConsole ? (
      <div slot="status" class="admin-status-slot">
        <p id="admin-content-status-live" class="admin-sr-only" role="status" aria-live="polite" aria-atomic="true"></p>
        <p id="admin-content-status" class="admin-status" data-state="idle">項目を選択してください</p>
      </div>
    ) : null}

    {
      shouldShowContentConsole && pageData ? (
        <section class="admin-overview admin-content-console" data-admin-content-root>
          <form class="admin-overview-card admin-content-toolbar" method="get">
            <div class="admin-content-toolbar__bar">
              <div class="admin-content-toolbar__intro">
                <p class="admin-overview-card__eyebrow">Content</p>
                <h2 class="admin-overview-card__title">{pageData.collectionLabel} 一覧</h2>
                <p class="admin-overview-card__body">
                  該当 {pageData.filteredCount} / {pageData.totalCount} 件、
                  現在 {pageData.currentPage} / {pageData.totalPages} ページ目です。
                  {activeFilterCount > 0 ? ` ${activeFilterCount} 件のフィルターを適用中。` : ' 現在は標準の日時順で表示しています。'}
                </p>
              </div>
              <div class="admin-content-switcher" role="tablist" aria-label="コンテンツ種別の切り替え">
                {
                  ADMIN_CONTENT_COLLECTIONS.map((item) => {
                    const href = withBase(getAdminContentCollectionHref(item));
                    const isActive = item === collection;
                    return (
                      <a
                        href={href}
                        class:list={['admin-content-switcher__link', isActive && 'is-active']}
                        aria-current={isActive ? 'page' : undefined}
                      >
                        {item}
                      </a>
                    );
                  })
                }
              </div>
            </div>

            <div class="admin-content-filter-grid">
              <label class="admin-field admin-content-field admin-content-field--query">
                <span class="admin-field__label">title / entry.id / slug を検索</span>
                <input class="admin-field__control" type="search" name="q" value={pageData.filterState.query} placeholder="スペース区切りで検索できます" />
              </label>

              <label class="admin-field admin-content-field">
                <span class="admin-field__label">下書きフィルター</span>
                <select class="admin-field__control" name="draft">
                  {
                    ADMIN_CONTENT_DRAFT_OPTIONS.map((option) => (
                      <option value={option.value} selected={option.value === pageData.filterState.draft}>
                        {option.label}
                      </option>
                    ))
                  }
                </select>
              </label>

              <label class="admin-field admin-content-field">
                <span class="admin-field__label">並び順</span>
                <select class="admin-field__control" name="sort">
                  {
                    ADMIN_CONTENT_SORT_OPTIONS.map((option) => (
                      <option value={option.value} selected={option.value === pageData.filterState.sort}>
                        {option.label}
                      </option>
                    ))
                  }
                </select>
              </label>

              {
                pageData.tagOptions.length > 0 ? (
                  <label class="admin-field admin-content-field">
                    <span class="admin-field__label">タグ</span>
                    <select class="admin-field__control" name="tag">
                      <option value="">すべてのタグ</option>
                      {
                        pageData.tagOptions.map((option) => (
                          <option value={option.value} selected={option.value === pageData.filterState.tag}>
                            {option.label} ({option.count})
                          </option>
                        ))
                      }
                    </select>
                  </label>
                ) : null
              }

              {
                pageData.yearOptions.length > 0 ? (
                  <label class="admin-field admin-content-field">
                    <span class="admin-field__label">年</span>
                    <select class="admin-field__control" name="year">
                      <option value="">すべての年</option>
                      {
                        pageData.yearOptions.map((option) => (
                          <option
                            value={option.value}
                            selected={option.value === (pageData.filterState.year !== null ? String(pageData.filterState.year) : '')}
                          >
                            {option.label} ({option.count})
                          </option>
                        ))
                      }
                    </select>
                  </label>
                ) : null
              }
            </div>

            <div class="admin-content-toolbar__footer">
              <p class="admin-content-toolbar__hint">
                {pageData.hasActiveFilters
                  ? '現在のURLにフィルター状態が記録されているため、この検索結果をそのまま保持できます。'
                  : '項目を選ぶと下に索引の詳細を表示します。essay / bits は frontmatter 編集カードを追加し、memo は読み取り専用のままです。'}
              </p>
              <div class="admin-overview-card__actions">
                <button class="admin-btn admin-btn--secondary" type="submit">フィルターを適用</button>
                <a class="admin-btn admin-btn--ghost" href={resetHref}>条件をリセット</a>
                <a class="admin-btn admin-btn--ghost" href={withBase('/admin/content/')}>コンテンツ管理トップへ戻る</a>
              </div>
            </div>
          </form>

          {
            pageData.selectedEntry ? (
              <article class="admin-overview-card admin-content-inspector">
                <div class="admin-content-inspector__head">
                  <div class="admin-content-inspector__intro">
                    <p class="admin-overview-card__eyebrow">現在の項目</p>
                    <h2 class="admin-overview-card__title">{pageData.selectedEntry.title}</h2>
                    <p class="admin-overview-card__body">
                      パス、frontmatter、管理用の要約を表示します。書き込み対象の collection では、下に frontmatter 編集カードを表示します。
                    </p>
                  </div>
                  <div class="admin-overview-card__actions">
                    <button
                      type="button"
                      class="admin-btn admin-btn--secondary"
                      data-admin-copy-button
                      data-copy-label="相対パス"
                      data-copy-text={selectedEntryRelativePath}
                    >
                      パスをコピー
                    </button>
                    <button
                      type="button"
                      class="admin-btn admin-btn--ghost"
                      data-admin-copy-button
                      data-copy-label="entry.id"
                      data-copy-text={pageData.selectedEntry.id}
                    >
                      entry.id をコピー
                    </button>
                    {
                      pageData.selectedEntry.publicHref ? (
                        <a class="admin-btn admin-btn--ghost" href={withBase(pageData.selectedEntry.publicHref)}>公開ページを見る</a>
                      ) : null
                    }
                  </div>
                </div>

                {
                  pageData.selectedEntry.publicHref ? null : (
                    <p class="admin-content-inspector__note">{getAdminContentPublicFallbackLabel(pageData.selectedEntry)}</p>
                  )
                }

                <div class="admin-content-inspector__grid">
                  <section class="admin-content-inspector__block">
                    <h3 class="admin-content-frontmatter__title">索引メタ情報</h3>
                    <dl class="admin-data-meta admin-content-detail-meta">
                      <dt class="admin-data-meta__label">collection</dt>
                      <dd class="admin-data-meta__value">{pageData.selectedEntry.collection}</dd>
                      <dt class="admin-data-meta__label">entry.id</dt>
                      <dd class="admin-data-meta__value"><code>{pageData.selectedEntry.id}</code></dd>
                      <dt class="admin-data-meta__label">relative path</dt>
                      <dd class="admin-data-meta__value"><code>{selectedEntryRelativePath}</code></dd>
                      <dt class="admin-data-meta__label">public slug</dt>
                      <dd class="admin-data-meta__value">
                        {pageData.selectedEntry.slug ? <code>{pageData.selectedEntry.slug}</code> : '(未設定)'}
                      </dd>
                      <dt class="admin-data-meta__label">date</dt>
                      <dd class="admin-data-meta__value">{pageData.selectedEntry.dateLabel}</dd>
                    </dl>
                  </section>

                  <section class="admin-content-inspector__block">
                    <h3 class="admin-content-frontmatter__title">主要 frontmatter</h3>
                    <dl class="admin-data-meta admin-content-detail-meta">
                      {
                        pageData.selectedEntry.frontmatterFields.map((field) => (
                          <>
                            <dt class="admin-data-meta__label">{field.label}</dt>
                            <dd class="admin-data-meta__value">{field.value}</dd>
                          </>
                        ))
                      }
                    </dl>
                  </section>

                  <section class="admin-content-inspector__block admin-content-inspector__block--summary">
                    <h3 class="admin-content-frontmatter__title">管理用の要約</h3>
                    <p class="admin-overview-card__body">
                      {pageData.selectedEntry.excerpt ?? 'この項目には表示できる管理用の要約がまだ生成されていません。'}
                    </p>
                  </section>
                </div>
              </article>
            ) : null
          }

          {
            selectedEntryEditorPayload ? (
              selectedEntryEditorPayload.writable ? (
                <article class="admin-overview-card admin-content-panel admin-content-editor">
                  <div class="admin-content-panel__head">
                    <div>
                      <p class="admin-overview-card__eyebrow">Frontmatter Editor</p>
                       <h2 class="admin-overview-card__title">最初に書き込み対応する項目</h2>
                      <p class="admin-overview-card__body">
                         現在は {selectedEntryEditorPayload.collection} の frontmatter 書き戻しのみ有効です。保存前に
                         dry-run を実行できます。本文は引き続き読み取り専用で、この段階ではブラウザから書き込みません。
                      </p>
                    </div>
                    <div class="admin-content-results__meta">
                      <span class="admin-badge">revision</span>
                      <code class="admin-content-editor__revision">{selectedEntryEditorPayload.revision}</code>
                    </div>
                  </div>

                  <AdminDiagnosticPanel
                    bannerId="admin-content-editor-error-banner"
                    titleId="admin-content-editor-error-title"
                    messageId="admin-content-editor-error-message"
                    listId="admin-content-editor-error-list"
                     title="frontmatter は書き込まれていません"
                     label="書き込みエラー"
                  />

                  <form id="admin-content-editor-form" class="admin-content-editor__form">
                    <div class="admin-content-editor__grid">
                      {
                        selectedEntryEditorPayload.collection === 'essay' ? (
                          <>
                            <label class="admin-field admin-content-editor__field" data-field-path="title">
                              <span class="admin-field__label">title</span>
                              <input class="admin-field__control" id="admin-content-title" name="title" type="text" value={selectedEntryEditorPayload.values.title} />
                              <p class="admin-content-editor__error" data-field-error="title" hidden></p>
                            </label>

                            <label class="admin-field admin-content-editor__field" data-field-path="date">
                              <span class="admin-field__label">date</span>
                              <input class="admin-field__control" id="admin-content-date" name="date" type="date" value={selectedEntryEditorPayload.values.date} />
                              <p class="admin-content-editor__error" data-field-error="date" hidden></p>
                            </label>

                            <label class="admin-field admin-content-editor__field admin-field--full" data-field-path="description">
                              <span class="admin-field__label">description</span>
                              <textarea class="admin-field__control" id="admin-content-description" name="description">{selectedEntryEditorPayload.values.description}</textarea>
                              <p class="admin-content-editor__error" data-field-error="description" hidden></p>
                            </label>

                            <label class="admin-field admin-content-editor__field admin-field--full" data-field-path="tags">
                              <span class="admin-field__label">tags（每行一个）</span>
                              <textarea class="admin-field__control" id="admin-content-tags" name="tagsText">{selectedEntryEditorPayload.values.tagsText}</textarea>
                              <p class="admin-content-editor__error" data-field-error="tags" hidden></p>
                            </label>

                            <label class="admin-field admin-content-editor__field" data-field-path="slug">
                              <span class="admin-field__label">slug</span>
                              <input class="admin-field__control" id="admin-content-slug" name="slug" type="text" value={selectedEntryEditorPayload.values.slug} />
                              <p class="admin-content-editor__error" data-field-error="slug" hidden></p>
                            </label>

                            <label class="admin-field admin-content-editor__field" data-field-path="badge">
                              <span class="admin-field__label">badge</span>
                              <input class="admin-field__control" id="admin-content-badge" name="badge" type="text" value={selectedEntryEditorPayload.values.badge} />
                              <p class="admin-content-editor__error" data-field-error="badge" hidden></p>
                            </label>

                            <label class="admin-field admin-content-editor__field admin-field--full" data-field-path="cover">
                              <span class="admin-field__label">cover</span>
                              <input class="admin-field__control" id="admin-content-cover" name="cover" type="text" value={selectedEntryEditorPayload.values.cover} />
                              <p class="admin-content-editor__error" data-field-error="cover" hidden></p>
                            </label>

                            <div class="admin-content-editor__toggles">
                              <label class="admin-toggle-row">
                                <input id="admin-content-draft" name="draft" type="checkbox" checked={selectedEntryEditorPayload.values.draft} />
                                <span>draft</span>
                              </label>
                              <label class="admin-toggle-row">
                                <input id="admin-content-archive" name="archive" type="checkbox" checked={selectedEntryEditorPayload.values.archive} />
                                <span>archive</span>
                              </label>
                            </div>
                          </>
                        ) : selectedEntryEditorPayload.collection === 'bits' ? (
                          <>
                            <label class="admin-field admin-content-editor__field" data-field-path="title">
                              <span class="admin-field__label">title（可选）</span>
                              <input class="admin-field__control" id="admin-content-title" name="title" type="text" value={selectedEntryEditorPayload.values.title} />
                              <p class="admin-content-editor__error" data-field-error="title" hidden></p>
                            </label>

                            <label class="admin-field admin-content-editor__field" data-field-path="date">
                              <span class="admin-field__label">date</span>
                              <input class="admin-field__control" id="admin-content-date" name="date" type="text" value={selectedEntryEditorPayload.values.date} />
                              <p class="admin-content-editor__error" data-field-error="date" hidden></p>
                            </label>

                            <label class="admin-field admin-content-editor__field admin-field--full" data-field-path="description">
                              <span class="admin-field__label">description</span>
                              <textarea class="admin-field__control" id="admin-content-description" name="description">{selectedEntryEditorPayload.values.description}</textarea>
                              <p class="admin-content-editor__error" data-field-error="description" hidden></p>
                            </label>

                            <label class="admin-field admin-content-editor__field admin-field--full" data-field-path="tags">
                              <span class="admin-field__label">tags（每行一个）</span>
                              <textarea class="admin-field__control" id="admin-content-tags" name="tagsText">{selectedEntryEditorPayload.values.tagsText}</textarea>
                              <p class="admin-content-editor__error" data-field-error="tags" hidden></p>
                            </label>

                            <label class="admin-field admin-content-editor__field" data-field-path="authorName">
                              <span class="admin-field__label">author.name</span>
                              <input class="admin-field__control" id="admin-content-author-name" name="authorName" type="text" value={selectedEntryEditorPayload.values.authorName} />
                              <p class="admin-content-editor__error" data-field-error="authorName" hidden></p>
                            </label>

                            <label class="admin-field admin-content-editor__field" data-field-path="authorAvatar">
                              <span class="admin-field__label">author.avatar</span>
                              <input class="admin-field__control" id="admin-content-author-avatar" name="authorAvatar" type="text" value={selectedEntryEditorPayload.values.authorAvatar} />
                              <p class="admin-content-editor__error" data-field-error="authorAvatar" hidden></p>
                            </label>

                            <div class="admin-field admin-content-editor__field admin-field--full" data-field-path="imagesText">
                              <div class="admin-content-image-editor__header">
                                <span class="admin-field__label">images</span>
                                <button
                                  class="admin-btn admin-btn--ghost admin-content-image-editor__add"
                                  id="admin-content-image-add"
                                  type="button"
                                >
                                  + 画像を追加
                                </button>
                              </div>
                              <input
                                id="admin-content-images-json"
                                name="imagesText"
                                type="hidden"
                                value={selectedEntryEditorPayload.values.imagesText}
                              />
                              <p class="admin-content-image-editor__hint">
                                既存の `bits.images` 形式を維持します。ローカル相対パスまたは `https://` のリモートURLを指定できます。幅と高さは空欄でもよく、ローカル画像は選択ツールから自動入力できます。
                              </p>
                              <p class="admin-content-editor__error" data-field-error="imagesText" hidden></p>
                              <div class="admin-content-image-editor" id="admin-content-image-editor">
                                {
                                  bitsImageRows.map((image, index) => (
                                    <div class="admin-row admin-row--muted admin-row--interactive admin-content-image-row" data-admin-content-image-row>
                                      <div class="admin-content-image-row__head">
                                        <strong class="admin-content-image-row__title">画像 #{index + 1}</strong>
                                        <button
                                          class="admin-btn admin-btn--ghost admin-content-image-row__remove"
                                          type="button"
                                          data-admin-content-image-remove
                                        >
                                          移除
                                        </button>
                                      </div>
                                      <div class="admin-content-image-row__grid">
                                        <div class="admin-field admin-content-image-row__field admin-content-image-row__field--src" data-field-path={`images[${index}].src`}>
                                          <span class="admin-field__label">src</span>
                                          <div class="admin-content-image-row__src-inputs">
                                            <input
                                              class="admin-field__control"
                                              type="text"
                                              value={image.src}
                                              spellcheck="false"
                                              placeholder="bits/demo.webp 或 https://…"
                                              data-admin-content-image-src
                                            />
                                            <button
                                              class="admin-btn admin-btn--ghost"
                                              type="button"
                                              data-admin-content-image-pick
                                            >
                                              ローカル画像を選択
                                            </button>
                                          </div>
                                          <p class="admin-content-editor__error" data-field-error={`images[${index}].src`} hidden></p>
                                        </div>
                                        <label class="admin-field admin-content-image-row__field" data-field-path={`images[${index}].width`}>
                                          <span class="admin-field__label">width</span>
                                          <input class="admin-field__control" type="number" min="1" step="1" value={image.width} data-admin-content-image-width />
                                          <p class="admin-content-editor__error" data-field-error={`images[${index}].width`} hidden></p>
                                        </label>
                                        <label class="admin-field admin-content-image-row__field" data-field-path={`images[${index}].height`}>
                                          <span class="admin-field__label">height</span>
                                          <input class="admin-field__control" type="number" min="1" step="1" value={image.height} data-admin-content-image-height />
                                          <p class="admin-content-editor__error" data-field-error={`images[${index}].height`} hidden></p>
                                        </label>
                                        <label class="admin-field admin-content-image-row__field admin-content-image-row__field--alt">
                                          <span class="admin-field__label">alt（可选）</span>
                                          <input class="admin-field__control" type="text" value={image.alt} data-admin-content-image-alt />
                                        </label>
                                      </div>
                                      <div class="admin-content-image-row__footer">
                                        <p class="admin-content-image-row__meta" data-admin-content-image-meta>画像を選択するかパスを入力してください</p>
                                        <div class="admin-content-image-row__preview" data-admin-content-image-preview hidden>
                                          <img alt="" loading="lazy" decoding="async" data-admin-content-image-preview-img />
                                        </div>
                                      </div>
                                    </div>
                                  ))
                                }
                              </div>
                              <template id="admin-content-image-row-template">
                                <div class="admin-row admin-row--muted admin-row--interactive admin-content-image-row" data-admin-content-image-row>
                                  <div class="admin-content-image-row__head">
                                    <strong class="admin-content-image-row__title">画像</strong>
                                    <button
                                      class="admin-btn admin-btn--ghost admin-content-image-row__remove"
                                      type="button"
                                      data-admin-content-image-remove
                                    >
                                      移除
                                    </button>
                                  </div>
                                  <div class="admin-content-image-row__grid">
                                    <div class="admin-field admin-content-image-row__field admin-content-image-row__field--src" data-field-path="images[0].src">
                                      <span class="admin-field__label">src</span>
                                      <div class="admin-content-image-row__src-inputs">
                                        <input
                                          class="admin-field__control"
                                          type="text"
                                          spellcheck="false"
                                          placeholder="bits/demo.webp 或 https://…"
                                          data-admin-content-image-src
                                        />
                                        <button
                                          class="admin-btn admin-btn--ghost"
                                          type="button"
                                          data-admin-content-image-pick
                                        >
                                          ローカル画像を選択
                                        </button>
                                      </div>
                                      <p class="admin-content-editor__error" data-field-error="images[0].src" hidden></p>
                                    </div>
                                    <label class="admin-field admin-content-image-row__field" data-field-path="images[0].width">
                                      <span class="admin-field__label">width</span>
                                      <input class="admin-field__control" type="number" min="1" step="1" data-admin-content-image-width />
                                      <p class="admin-content-editor__error" data-field-error="images[0].width" hidden></p>
                                    </label>
                                    <label class="admin-field admin-content-image-row__field" data-field-path="images[0].height">
                                      <span class="admin-field__label">height</span>
                                      <input class="admin-field__control" type="number" min="1" step="1" data-admin-content-image-height />
                                      <p class="admin-content-editor__error" data-field-error="images[0].height" hidden></p>
                                    </label>
                                    <label class="admin-field admin-content-image-row__field admin-content-image-row__field--alt">
                                      <span class="admin-field__label">alt（可选）</span>
                                      <input class="admin-field__control" type="text" data-admin-content-image-alt />
                                    </label>
                                  </div>
                                  <div class="admin-content-image-row__footer">
                                    <p class="admin-content-image-row__meta" data-admin-content-image-meta>画像を選択するかパスを入力してください</p>
                                    <div class="admin-content-image-row__preview" data-admin-content-image-preview hidden>
                                      <img alt="" loading="lazy" decoding="async" data-admin-content-image-preview-img />
                                    </div>
                                  </div>
                                </div>
                              </template>
                            </div>

                            <div class="admin-content-editor__toggles">
                              <label class="admin-toggle-row">
                                <input id="admin-content-draft" name="draft" type="checkbox" checked={selectedEntryEditorPayload.values.draft} />
                                <span>draft</span>
                              </label>
                            </div>
                          </>
                        ) : null
                      }
                    </div>
                  </form>

                  <article id="admin-content-write-preview" class="admin-overview-card admin-content-editor__preview" hidden>
                    <p id="admin-content-write-preview-title" class="admin-overview-card__title">dry-run 結果</p>
                    <p id="admin-content-write-preview-body" class="admin-overview-card__body"></p>
                    <ul id="admin-content-write-preview-list" class="admin-content-editor__preview-list"></ul>
                  </article>

                  <div class="admin-content-toolbar__footer">
                    <p class="admin-content-toolbar__hint">
                      実際に書き込む前に revision を再検証します。現在の項目が外部で変更されている場合、管理画面は上書きを拒否し、更新を求めます。
                    </p>
                    <div class="admin-overview-card__actions">
                      <button id="admin-content-dry-run" class="admin-btn admin-btn--secondary" type="button">执行 dry-run</button>
                      <button id="admin-content-save" class="admin-btn admin-btn--primary" type="button">保存 frontmatter</button>
                    </div>
                  </div>

                  <div id="admin-content-bootstrap" hidden>{adminContentBootstrap}</div>
                </article>
              ) : (
                <article class="admin-overview-card admin-content-panel admin-content-editor admin-content-editor--readonly">
                  <p class="admin-overview-card__eyebrow">Readonly Schema</p>
                  <h2 class="admin-overview-card__title">現在の collection は引き続き読み取り専用です</h2>
                  <p class="admin-overview-card__body">
                    {selectedEntryEditorPayload.readonlyReason}
                  </p>
                  <dl class="admin-data-meta admin-content-detail-meta">
                    <dt class="admin-data-meta__label">memo.date</dt>
                    <dd class="admin-data-meta__value">任意項目のため、必須ではありません</dd>
                    <dt class="admin-data-meta__label">memo.slug</dt>
                    <dd class="admin-data-meta__value">使用普通字符串，不复用 essay 的 slugRule 正则</dd>
                  </dl>
                </article>
              )
            ) : null
          }

          <article class="admin-overview-card admin-content-panel admin-content-results">
            <div class="admin-content-panel__head admin-content-panel__head--results">
              <div>
                <p class="admin-overview-card__eyebrow">Results</p>
                <h2 class="admin-overview-card__title">{pageData.collectionLabel} 条目</h2>
                <p class="admin-overview-card__body">
                  {pageData.hasActiveFilters
                    ? '現在の結果はフィルター条件で絞り込まれています。詳細は一覧の上に表示されます。'
                    : '一覧ではタイトル、パス、slug、公開状態を優先して表示し、項目をすばやく見つけられるようにしています。'}
                </p>
              </div>
              <div class="admin-content-results__meta">
                <span class="admin-badge">page {pageData.currentPage}/{pageData.totalPages}</span>
                <span class="admin-badge">{pageData.pageItems.length} 项</span>
                {activeFilterCount > 0 ? <span class="admin-badge">フィルター {activeFilterCount}</span> : null}
              </div>
            </div>

            {
              pageData.pageItems.length > 0 ? (
                <>
                  <ol class="admin-content-list">
                    {
                      pageData.pageItems.map((item) => {
                        const isActive = pageData.selectedEntry?.id === item.id;
                        const detailHref = buildCurrentCollectionHref({
                          page: String(pageData.currentPage),
                          entry: item.id
                        });
                        return (
                          <li class:list={['admin-row', 'admin-row--interactive', 'admin-content-item', isActive && 'is-active']}>
                            <div class="admin-content-item__body">
                              <div class="admin-content-item__header">
                                <p class="admin-content-item__eyebrow">
                                  <span>{item.dateLabel}</span>
                                  <span aria-hidden="true">/</span>
                                  <span>{item.collectionLabel}</span>
                                </p>
                                <div class="admin-content-item__title-row">
                                  <a class="admin-content-item__title" href={detailHref}>{item.title}</a>
                                  {isActive ? <span class="admin-badge">現在</span> : null}
                                  {item.isDraft ? <span class="admin-badge">draft</span> : null}
                                  {item.archive === false ? <span class="admin-badge">archive off</span> : null}
                                </div>
                              </div>

                              <dl class="admin-content-item__facts">
                                <div class="admin-content-item__fact">
                                  <dt>entry.id</dt>
                                  <dd><code>{item.id}</code></dd>
                                </div>
                                <div class="admin-content-item__fact">
                                  <dt>path</dt>
                                  <dd><code>{item.relativePath}</code></dd>
                                </div>
                                <div class="admin-content-item__fact">
                                  <dt>slug</dt>
                                  <dd>{item.slug ? <code>{item.slug}</code> : '(未設定)'}</dd>
                                </div>
                              </dl>

                              {item.excerpt ? <p class="admin-content-item__excerpt">{item.excerpt}</p> : null}
                              {
                                item.tags.length > 0 ? (
                                  <p class="admin-content-item__tags">
                                    {item.tags.map((tag) => (
                                      <span class="admin-badge">#{tag}</span>
                                    ))}
                                  </p>
                                ) : null
                              }
                            </div>

                            <div class="admin-content-item__actions">
                              <a class:list={['admin-btn', isActive ? 'admin-btn--secondary' : 'admin-btn--ghost']} href={detailHref}>
                                {isActive ? '現在の項目' : '查看详情'}
                              </a>
                              {
                                item.publicHref ? (
                                  <a class="admin-btn admin-btn--ghost" href={withBase(item.publicHref)}>公开页</a>
                                ) : (
                                  <span class="admin-content-item__hint">{getAdminContentPublicFallbackLabel(item)}</span>
                                )
                              }
                            </div>
                          </li>
                        );
                      })
                    }
                  </ol>

                  {
                    pageData.totalPages > 1 ? (
                      <nav class="admin-content-pagination" aria-label="コンテンツのページ切り替え">
                        <div class="admin-overview-card__actions">
                          {
                            pageData.currentPage > 1 ? (
                              <a
                                class="admin-btn admin-btn--ghost"
                                href={buildCurrentCollectionHref({
                                  page: String(pageData.currentPage - 1),
                                  entry: ''
                                })}
                                rel="prev"
                              >
                                前のページ
                              </a>
                            ) : null
                          }
                          {
                            Array.from({ length: pageData.totalPages }, (_, index) => index + 1).map((page) => (
                              <a
                                class:list={['admin-btn', page === pageData.currentPage ? 'admin-btn--secondary' : 'admin-btn--ghost']}
                                href={buildCurrentCollectionHref({
                                  page: String(page),
                                  entry: ''
                                })}
                                aria-current={page === pageData.currentPage ? 'page' : undefined}
                              >
                                {page}
                              </a>
                            ))
                          }
                          {
                            pageData.currentPage < pageData.totalPages ? (
                              <a
                                class="admin-btn admin-btn--ghost"
                                href={buildCurrentCollectionHref({
                                  page: String(pageData.currentPage + 1),
                                  entry: ''
                                })}
                                rel="next"
                              >
                                次のページ
                              </a>
                            ) : null
                          }
                        </div>
                      </nav>
                    ) : null
                  }
                </>
              ) : (
                <p class="admin-content-empty">
                  現在のフィルター条件に一致する項目がありません。検索語を消す、draft 状態を切り替える、タグや年の制限を外すなどを試してください。
                </p>
              )
            }
          </article>
        </section>
      ) : (
        <AdminReadonlyNotice>
          管理画面の記事管理とビジュアル編集は開発中です。
        </AdminReadonlyNotice>
      )
    }
  </AdminShell>
  {shouldShowContentConsole ? <AdminImagePicker listEndpoint={adminImageListEndpoint} metaEndpoint={adminImageMetaEndpoint} /> : null}

  {
    shouldShowContentConsole && contentDevState?.adminContentScriptHref ? (
      <script is:inline type="module" src={contentDevState.adminContentScriptHref}></script>
    ) : null
  }
</AdminLayout>
