---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import AdminReadonlyNotice from '../../../components/admin/AdminReadonlyNotice.astro';
import AdminShell from '../../../components/admin/AdminShell.astro';
import {
  getAdminContentCollectionHref,
  getAdminContentOverviewData
} from '../../../lib/admin-console/content';
import { createWithBase } from '../../../utils/format';

const isDev = import.meta.env.DEV;
// Content Console 暂停对 dev 环境开放，保留实现供后续前端技术栈重构恢复。
const isAdminContentConsoleEnabled: boolean = false;
const shouldShowContentConsole = isDev && isAdminContentConsoleEnabled;
const shouldShowAdminNav = isDev;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const { default: adminShellStylesHref } = await import('../../../styles/components/admin-shell.css?url');

const loadContentOverviewDevState = async () => {
  const { default: adminContentStylesHref } = await import('../../../styles/components/admin-content.css?url');

  return {
    stylesHref: [adminShellStylesHref, adminContentStylesHref],
    overview: await getAdminContentOverviewData()
  };
};

const contentOverviewDevState = shouldShowContentConsole ? await loadContentOverviewDevState() : null;
const adminStylesHref = contentOverviewDevState?.stylesHref ?? adminShellStylesHref;
const contentOverviewTotals = contentOverviewDevState
  ? contentOverviewDevState.overview.summaries.reduce(
      (acc, summary) => ({
        totalCount: acc.totalCount + summary.totalCount,
        draftCount: acc.draftCount + summary.draftCount
      }),
      { totalCount: 0, draftCount: 0 }
    )
  : null;
---

<AdminLayout title="Content Console" stylesHref={adminStylesHref}>
  <AdminShell
    currentRoute="content"
    title="Content Console"
    subtitle="内容管理"
    showNav={shouldShowAdminNav}
  >
    {
      shouldShowContentConsole && contentOverviewDevState ? (
        <section class="admin-overview admin-content-home">
          <article class="admin-overview-card admin-content-home__lead">
            <div class="admin-content-home__lead-copy">
              <p class="admin-overview-card__eyebrow">Content</p>
              <h2 class="admin-overview-card__title">内容总览</h2>
              <p class="admin-overview-card__body">
                当前共收口 {contentOverviewTotals?.totalCount ?? 0} 条内容，其中草稿 {contentOverviewTotals?.draftCount ?? 0} 条。
                当前页面只负责 collection 概览与能力分流；具体筛选、分页与编辑入口放在各 collection 列表页。
              </p>
            </div>
            <div class="admin-overview-card__actions admin-content-home__lead-actions">
              <a class="admin-btn admin-btn--primary" href={withBase('/admin/content/essay/')}>进入 Essay 列表</a>
              <a class="admin-btn admin-btn--ghost" href={withBase('/admin/')}>返回 Admin 首页</a>
            </div>
          </article>

          <div class="admin-content-home__rail">
            {
              contentOverviewDevState.overview.summaries.map((summary) => (
                <article class="admin-overview-card admin-content-home__collection">
                  <div class="admin-content-home__collection-head">
                    <p class="admin-overview-card__eyebrow">{summary.key}</p>
                    {summary.draftCount > 0 ? <span class="admin-badge">draft {summary.draftCount}</span> : null}
                  </div>
                  <h2 class="admin-overview-card__title">{summary.label}</h2>
                  <p class="admin-overview-card__body">
                    共 {summary.totalCount} 条内容，其中草稿 {summary.draftCount} 条；最近更新时间 {summary.latestDateLabel}。
                  </p>
                  <div class="admin-overview-card__actions">
                    <a class="admin-btn admin-btn--secondary" href={withBase(getAdminContentCollectionHref(summary.key))}>
                      进入 {summary.label}
                    </a>
                  </div>
                </article>
              ))
            }
          </div>

          <article class="admin-overview-card admin-content-home__boundary">
            <p class="admin-overview-card__eyebrow">Current Boundary</p>
            <h2 class="admin-overview-card__title">当前入口负责总览与分流</h2>
            <ul class="admin-overview-card__list">
              <li>真实路由：`/admin/content/` 与 `/admin/content/:collection/`。</li>
              <li>URL 次级状态：`q / draft / tag / year / sort / page / entry`。</li>
              <li>维护动作：公开页跳转、路径复制、`entry.id` 复制。</li>
              <li>`essay / bits` 的 frontmatter dry-run 与保存已下沉到 collection 页；`memo` 继续只读。</li>
              <li>正文编辑与正文写盘仍不在当前范围内。</li>
            </ul>
          </article>
        </section>
      ) : (
        <AdminReadonlyNotice>
          后台文章管理与可视化写作正在开发中。
        </AdminReadonlyNotice>
      )
    }
  </AdminShell>
</AdminLayout>
